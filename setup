#!/bin/bash
set -e

SKILLS_DIR="$HOME/.claude/skills"
KSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "Installing KStack skills to $SKILLS_DIR..."

mkdir -p "$SKILLS_DIR"

SKILLS=(
  "trend-scan"
  "biz-context"
  "scan-blockers"
  "persona-build"
  "journey-map"
  "service-map"
  "synthesize"
  "biz-case"
  "prioritize"
  "brand-building-blocks"
  "brand-territories"
)

for skill in "${SKILLS[@]}"; do
  src="$KSTACK_DIR/$skill"
  dest="$SKILLS_DIR/$skill"

  if [ -L "$dest" ]; then
    rm "$dest"
  elif [ -d "$dest" ]; then
    echo "  Warning: $dest exists and is not a symlink. Skipping $skill."
    continue
  fi

  ln -s "$src" "$dest"
  echo "  ✓ $skill"
done

echo ""
echo "KStack installed. Skills available as slash commands in Claude Code:"
echo ""
for skill in "${SKILLS[@]}"; do
  echo "  /$skill"
done
echo ""
echo "Start with /trend-scan, /biz-context, or /scan-blockers for a new project."
